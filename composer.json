{
	"name": "jesgs-interactive/wp-block-template-sync",
	"description": "A WordPress plugin that syncs changes to theme templates in the Site Editor with the files in the theme.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5",
		"brain/monkey": "^2.7",
		"phing/phing": "^3.1",
		"pestphp/pest": "^3.8"
	},
	"autoload": {
		"classmap": [
			"includes/"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"WpBlockTemplateSync\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"pest": "pest --colors=always",
		"phpunit": "phpunit",
		"test": "pest"
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	}
}
